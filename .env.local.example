# Copy this file to .env.local and fill in your values

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3001

# Admin credentials — password must be a bcrypt hash
# Generate with: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(console.log)"
ADMIN_EMAIL=hello@midcenturist.co.za
ADMIN_PASSWORD=$2b$10$your_bcrypt_hash_here

# Flask backend base URL
NEXT_PUBLIC_API_URL=https://your-flask-api.onrender.com
